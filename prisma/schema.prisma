generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Conviction {
  HIGH
  MED
  LOW
}

enum PositionSize {
  LARGE
  MEDIUM
  SMALL
}

enum StockStatus {
  ACCUMULATE
  HOLD
  AVOID
}

enum TradeAction {
  BUY
  SELL
}

model Stock {
  id            String       @id @default(cuid())
  ticker        String       @unique
  name          String
  driver        String
  industry      String?
  conviction    Conviction
  positionSize  PositionSize
  status        StockStatus
  synopsis      String?
  entryTiers    String? // JSON: { first, add, heavy }
  catalysts     String? // JSON string[]
  risks         String? // JSON string[]
  nextEarnings  DateTime?
  notes         String?

  // SA Premium data (manually entered by user)
  saQuantRating    String?
  saFactorGrades   String? // JSON: { valuation, growth, profitability, momentum, revisions }
  saAuthorRating   String?

  trades        Trade[]
  priceCache    PriceCache?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Trade {
  id       String      @id @default(cuid())
  stockId  String
  stock    Stock       @relation(fields: [stockId], references: [id], onDelete: Cascade)
  action   TradeAction
  price    Float
  shares   Float
  date     DateTime
  note     String?

  createdAt DateTime @default(now())
}

model PriceCache {
  id            String   @id @default(cuid())
  stockId       String   @unique
  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  ticker        String
  price         Float?
  changePercent Float?
  peRatio       Float?
  peerAvgPE     Float?
  marketCap     Float?
  beta          Float?
  fetchedAt     DateTime @default(now())
}

model PriceBar {
  id     String   @id @default(cuid())
  ticker String
  date   DateTime
  open   Float
  high   Float
  low    Float
  close  Float
  volume Float?

  @@unique([ticker, date])
  @@index([ticker])
}

model MarketMover {
  id            String   @id @default(cuid())
  ticker        String
  name          String?
  price         Float?
  changePercent Float?
  exchange      String?
  category      String // GAINER | LOSER | ACTIVE
  fetchedAt     DateTime @default(now())

  @@unique([ticker, category])
}
